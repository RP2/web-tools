---
import BackButton from "../../components/BackButton.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Glitch Studio - Riley's Web Tools"
  description="Upload JPEG images and apply customizable glitch effects to generate stylized poster art."
  tags="free, open source, private, web based, tool, glitch, art, image effects, p5js"
>
  <BackButton />
  <div class="mx-auto mt-9 flex max-w-6xl flex-col gap-6 p-4 lg:flex-row">
    <div class="flex-1">
      <div
        id="canvas-container"
        class="relative h-[400px] w-full overflow-hidden rounded-lg border border-neutral-200 bg-neutral-100 lg:h-[600px]"
      >
        <div
          id="upload-overlay"
          class="absolute inset-0 z-10 flex cursor-pointer flex-col items-center justify-center bg-neutral-50 transition-colors hover:bg-neutral-100"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-12 w-12 text-neutral-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
          <p class="mt-3 text-neutral-500">Click or drag JPEG here to upload</p>
        </div>
      </div>
    </div>
    <div id="controls-container" class="w-full lg:w-72"></div>
  </div>
  <input
    type="file"
    id="file-input"
    accept="image/jpeg,image/jpg"
    class="hidden"
  />
</Layout>

<script>
  import { initSketch, loadImage } from "../../scripts/glitch-studio/sketch";

  const fileInput = document.getElementById("file-input") as HTMLInputElement;
  const canvasContainer = document.getElementById("canvas-container")!;
  const uploadOverlay = document.getElementById("upload-overlay")!;
  const controlsContainer = document.getElementById("controls-container")!;

  initSketch(canvasContainer, uploadOverlay, controlsContainer);

  uploadOverlay.addEventListener("click", () => {
    fileInput.click();
  });

  fileInput.addEventListener("change", (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file) {
      handleFile(file);
    }
  });

  uploadOverlay.addEventListener("dragover", (e) => {
    e.preventDefault();
    uploadOverlay.classList.add("bg-neutral-100");
  });

  uploadOverlay.addEventListener("dragleave", () => {
    uploadOverlay.classList.remove("bg-neutral-100");
  });

  uploadOverlay.addEventListener("drop", (e) => {
    e.preventDefault();
    uploadOverlay.classList.remove("bg-neutral-100");
    const file = e.dataTransfer?.files[0];
    if (file && file.type.startsWith("image/jpeg")) {
      handleFile(file);
    }
  });

  function handleFile(file: File): void {
    if (!file.type.startsWith("image/jpeg")) {
      alert("Please upload a JPEG image");
      return;
    }
    loadImage(file, uploadOverlay);
  }
</script>
